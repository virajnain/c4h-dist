FROM ubuntu:22.04

# System packages needed by Spack
RUN apt-get update && apt-get install -y \
    bash \
    git \
    curl \
    python3 \
    build-essential \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Spack
WORKDIR /opt
RUN git clone https://github.com/spack/spack.git

# Use bash shell for source commands
SHELL ["/bin/bash", "-c"]

# Verify Spack works
RUN . /opt/spack/share/spack/setup-env.sh && \
    spack --version

CMD ["/bin/bash"]